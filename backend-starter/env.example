# ── Database ─────────────────────────────────────────────────────────────────
# IMPORTANT: SQLAlchemy + psycopg v3 requires the "+psycopg" driver prefix.
# Neon gives you "postgresql://..." — change it to "postgresql+psycopg://..."
# Also remove "channel_binding=require" — psycopg3 does not support that param.
DATABASE_URL=postgresql+psycopg://neondb_owner:npg_8JNmlaqQ1vZb@ep-fancy-water-ap40814i-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=mK9xR2vL8pQ4nZ7wY1tA6sD3fG0hJ5kE2uO9iB4cX8rV6yN1mW3qP7lT0aS5dF
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=10080

# ── CORS ─────────────────────────────────────────────────────────────────────
# After Vercel deployment, set this to your real Vercel URL. No trailing slash.
CORS_ORIGINS=https://ironlog.vercel.app

# ── Environment ──────────────────────────────────────────────────────────────
# "production" disables Swagger UI (/docs) — keep this in Render env vars
ENV=production

# ── Resend ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=IronLog <noreply@ironlog.app>
